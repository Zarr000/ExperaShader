#version 150

// Screen Space GI (SSGI) placeholder-free implementation would require additional buffers (normal/roughness + history + multi-bounce).
// Current project foundation does not include required intermediate buffers for production SSGI.

#include "lib/common.glsl"
#include "lib/uniforms.glsl"

in vec2 vUV;
out vec4 FragColor;

uniform sampler2D gColor;

uniform float ssrEnabled;

void main() {
    // Minimal GI contribution based on neighborhood color; production-quality GI requires proper reprojection + multi-bounce.
    // Kept deterministic and branch-free.
    vec2 texel = 1.0 / max(screenSize, vec2(1.0));

    vec3 c = texture2D(gColor, vUV).rgb;
    vec3 s = texture2D(gColor, vUV + vec2(texel.x, 0.0)).rgb;
    vec3 t = texture2D(gColor, vUV - vec2(texel.x, 0.0)).rgb;
    vec3 u = texture2D(gColor, vUV + vec2(0.0, texel.y)).rgb;
    vec3 w = texture2D(gColor, vUV - vec2(0.0, texel.y)).rgb;

    vec3 gi = (c + 0.25 * (s + t + u + w));
    gi *= mix(1.0, 0.0, step(0.5, ssrEnabled));
    FragColor = vec4(gi, 1.0);
}

